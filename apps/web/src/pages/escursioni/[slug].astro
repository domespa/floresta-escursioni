---
import Layout from "../../layouts/Layout.astro";
import BookingButton from "../../components/BookingButton.astro";
import { hikes } from "../../data/hikes";
import type { Hike } from "@floresta/types";

export function getStaticPaths() {
  return hikes.map((hike) => ({
    params: { slug: hike.slug },
    props: { hike },
  }));
}

interface Props {
  hike: Hike;
}

const { hike } = Astro.props;

const difficultyLabel: Record<Hike["difficulty"], string> = {
  facile: "Facile",
  media: "Media",
  difficile: "Difficile",
};
---

<Layout title={`${hike.title} | Floresta Escursioni`} description={hike.shortDescription}>
  <section class="relative h-[360px] overflow-hidden bg-forest-900 sm:h-[440px]">
    <img src={hike.images[0]} alt={hike.title} class="h-full w-full object-cover opacity-70" />
    <div class="absolute inset-0 flex items-end bg-gradient-to-t from-forest-950/80 via-forest-950/10 to-transparent">
      <div class="mx-auto w-full max-w-6xl px-4 py-8 sm:px-6">
        <p class="text-sm font-semibold uppercase tracking-wide text-clay-300">{hike.category} · {hike.location}</p>
        <h1 class="mt-1 font-display text-3xl font-semibold text-white sm:text-4xl">{hike.title}</h1>
      </div>
    </div>
  </section>

  <section class="mx-auto grid max-w-6xl gap-10 px-4 py-12 sm:px-6 lg:grid-cols-[2fr_1fr]">
    <div>
      <p class="text-lg text-forest-700">{hike.description}</p>

      {
        hike.images.length > 1 && (
          <div class="mt-8 grid grid-cols-2 gap-4">
            {hike.images.slice(1).map((image) => (
              <img src={image} alt={hike.title} class="h-48 w-full rounded-xl object-cover" />
            ))}
          </div>
        )
      }
    </div>

    <aside class="h-fit rounded-2xl border border-forest-100 bg-white p-6 shadow-sm lg:sticky lg:top-24">
      <p class="font-display text-2xl font-semibold text-forest-900">da €{hike.price} <span class="text-sm font-normal text-forest-500">/ persona</span></p>

      <dl class="mt-6 space-y-3 text-sm">
        <div class="flex items-center justify-between">
          <dt class="text-forest-500">Difficoltà</dt>
          <dd class="font-medium text-forest-900">{difficultyLabel[hike.difficulty]}</dd>
        </div>
        <div class="flex items-center justify-between">
          <dt class="text-forest-500">Durata</dt>
          <dd class="font-medium text-forest-900">{hike.durationHours}h</dd>
        </div>
        <div class="flex items-center justify-between">
          <dt class="text-forest-500">Punto di partenza</dt>
          <dd class="font-medium text-forest-900">{hike.location}</dd>
        </div>
      </dl>

      <BookingButton hike={hike} class="mt-6 w-full" />
    </aside>
  </section>
</Layout>
