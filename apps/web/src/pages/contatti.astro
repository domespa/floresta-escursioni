---
import Layout from "../layouts/Layout.astro";
import MapEmbed from "../components/MapEmbed.astro";

const whatsappNumber = "393802578776";
const whatsappMessage = encodeURIComponent("Ciao! Vorrei informazioni sulle escursioni di Floresta Escursioni.");
const address = "Corso Indipendenza, 29, 98030 Floresta ME";
---

<Layout
  title="Contatti | Floresta Escursioni"
  description="Contatta Floresta Escursioni per informazioni sulle escursioni guidate sui Nebrodi."
>
  <section class="border-b border-forest-100 bg-forest-50 py-14">
    <div class="mx-auto max-w-4xl px-4 sm:px-6">
      <p class="text-sm font-semibold uppercase tracking-wide text-clay-600">Contatti</p>
      <h1 class="mt-1 font-display text-4xl font-semibold text-forest-900">Scrivici, rispondiamo volentieri</h1>
      <p class="mt-3 max-w-xl text-forest-600">
        Per informazioni su un'escursione o per organizzare un'uscita di gruppo, contattaci direttamente: ti
        rispondiamo il prima possibile.
      </p>
    </div>
  </section>

  <section class="mx-auto max-w-4xl px-4 py-14 sm:px-6">
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      <a
        href={`https://wa.me/${whatsappNumber}?text=${whatsappMessage}`}
        target="_blank"
        rel="noopener noreferrer"
        class="rounded-2xl border border-forest-100 bg-white p-6 text-center shadow-sm transition-shadow hover:shadow-md"
      >
        <p class="font-display text-lg font-semibold text-forest-900">WhatsApp</p>
        <p class="mt-2 text-sm text-forest-600">Scrivici subito, è il modo più veloce</p>
      </a>

      <a
        href="tel:+393802578776"
        class="rounded-2xl border border-forest-100 bg-white p-6 text-center shadow-sm transition-shadow hover:shadow-md"
      >
        <p class="font-display text-lg font-semibold text-forest-900">Telefono</p>
        <p class="mt-2 text-sm text-forest-600">+39 380 257 8776</p>
      </a>

      <a
        href="mailto:info@florestaescursioni.it"
        class="rounded-2xl border border-forest-100 bg-white p-6 text-center shadow-sm transition-shadow hover:shadow-md"
      >
        <p class="font-display text-lg font-semibold text-forest-900">Email</p>
        <p class="mt-2 text-sm text-forest-600">info@florestaescursioni.it</p>
      </a>

      <a
        href={`https://maps.google.com/?q=${encodeURIComponent(address)}`}
        target="_blank"
        rel="noopener noreferrer"
        class="rounded-2xl border border-forest-100 bg-white p-6 text-center shadow-sm transition-shadow hover:shadow-md"
      >
        <p class="font-display text-lg font-semibold text-forest-900">Indirizzo</p>
        <p class="mt-2 text-sm text-forest-600">{address}</p>
      </a>
    </div>

    <div class="mt-10">
      <MapEmbed query={address} />
    </div>
  </section>
</Layout>