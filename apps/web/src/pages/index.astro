---
import Layout from "../layouts/Layout.astro";
import HikeCard from "../components/HikeCard.astro";
import { getFeaturedHikes } from "../data/hikes";

const featuredHikes = getFeaturedHikes();

const values = [
  {
    title: "Guide esperte del territorio",
    description: "Accompagnatori naturalistici che conoscono ogni sentiero dei Nebrodi e la loro storia.",
  },
  {
    title: "Gruppi piccoli",
    description: "Massimo 12 persone a escursione, per un'esperienza curata e a misura di ogni partecipante.",
  },
  {
    title: "Percorsi per tutti i livelli",
    description: "Dalle passeggiate in famiglia ai trekking più impegnativi, con difficoltà sempre indicata chiaramente.",
  },
];
---

<Layout>
  <section class="relative overflow-hidden bg-forest-900 text-white">
    <img
      src="https://picsum.photos/seed/nebrodi-hero/1600/900"
      alt="Boschi dei Nebrodi"
      class="absolute inset-0 h-full w-full object-cover opacity-40"
    />
    <div class="relative mx-auto max-w-6xl px-4 py-28 sm:px-6 sm:py-36">
      <p class="font-medium uppercase tracking-widest text-clay-300">Parco dei Nebrodi, Sicilia</p>
      <h1 class="mt-4 max-w-2xl font-display text-4xl font-semibold leading-tight sm:text-5xl">
        Scopri i Nebrodi un passo alla volta
      </h1>
      <p class="mt-6 max-w-xl text-lg text-forest-100">
        Escursioni guidate tra boschi secolari, laghi e gole, per chi vuole vivere la natura siciliana senza fretta.
      </p>
      <div class="mt-8 flex flex-wrap gap-4">
        <a
          href="/escursioni"
          class="rounded-full bg-clay-600 px-6 py-3 text-sm font-semibold text-white shadow-sm transition-colors hover:bg-clay-700"
        >
          Scopri le escursioni
        </a>
        <a
          href="/contatti"
          class="rounded-full border border-white/40 px-6 py-3 text-sm font-semibold text-white transition-colors hover:bg-white/10"
        >
          Contattaci
        </a>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 py-16 sm:px-6">
    <div class="grid gap-8 sm:grid-cols-3">
      {
        values.map((value) => (
          <div class="rounded-2xl border border-forest-100 bg-white p-6 shadow-sm">
            <h3 class="font-display text-lg font-semibold text-forest-900">{value.title}</h3>
            <p class="mt-2 text-sm text-forest-600">{value.description}</p>
          </div>
        ))
      }
    </div>
  </section>

  <section class="bg-forest-50 py-16">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <div class="flex items-end justify-between gap-4">
        <div>
          <p class="text-sm font-semibold uppercase tracking-wide text-clay-600">In evidenza</p>
          <h2 class="mt-1 font-display text-3xl font-semibold text-forest-900">Le escursioni più amate</h2>
        </div>
        <a href="/escursioni" class="hidden text-sm font-semibold text-forest-700 hover:text-clay-700 sm:block">
          Vedi tutte →
        </a>
      </div>

      <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {featuredHikes.map((hike) => <HikeCard hike={hike} />)}
      </div>

      <a
        href="/escursioni"
        class="mt-8 inline-block text-sm font-semibold text-forest-700 hover:text-clay-700 sm:hidden"
      >
        Vedi tutte le escursioni →
      </a>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 py-16 sm:px-6">
    <div class="rounded-3xl bg-clay-600 px-8 py-12 text-center text-white sm:px-16">
      <h2 class="font-display text-3xl font-semibold">Pronto a partire?</h2>
      <p class="mx-auto mt-3 max-w-xl text-clay-50">
        Scegli il percorso più adatto a te e prenota il tuo posto: le nostre guide ti aspettano sui sentieri dei Nebrodi.
      </p>
      <a
        href="/escursioni"
        class="mt-6 inline-block rounded-full bg-white px-6 py-3 text-sm font-semibold text-clay-700 transition-colors hover:bg-clay-50"
      >
        Scopri le escursioni
      </a>
    </div>
  </section>
</Layout>
