---
interface Props {
  query: string;
  zoom?: number;
  class?: string;
}

const { query, zoom = 16, class: className = "h-80 w-full" } = Astro.props;
const src = `https://maps.google.com/maps?q=${encodeURIComponent(query)}&z=${zoom}&output=embed`;
---

<div class:list={["overflow-hidden rounded-2xl border border-forest-100", className]}>
  <iframe
    title="Mappa"
    src={src}
    loading="lazy"
    referrerpolicy="no-referrer-when-downgrade"
    class="h-full w-full"
  ></iframe>
</div>
